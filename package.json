{
  "name": "lonelynathan",
  "version": "0.7.0",
  "main": "main.js",
  "scripts": {
    "check": "node --check *.js",
    "format": "biome format --write .",
    "lint": "biome check --write .",
    "start": "electron .",
    "clean": "rimraf dist",
    "build": "pnpm clean && electron-builder --publish never",
    "build:linux": "pnpm clean && electron-builder --linux --publish never",
    "build:mac": "pnpm clean && electron-builder --mac --publish never",
    "build:win": "pnpm clean && electron-builder --win --publish never"
  },
  "homepage": "https://lonelynathan.app",
  "bugs": {
    "url": "https://github.com/kkomelin/n8n-ollama-desktop/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kkomelin/n8n-ollama-desktop.git"
  },
  "keywords": [
    "n8n",
    "ollama",
    "electron",
    "desktop",
    "docker",
    "ai",
    "automation",
    "n8n-ollama-desktop",
    "lonelynathan"
  ],
  "author": "Konstantin Komelin <konstantin.komelin@gmail.com>",
  "license": "Apache-2.0",
  "description": "LonelyNathan — n8n + Ollama Desktop App",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "lefthook"
    ]
  },
  "build": {
    "appId": "app.lonelynathan.LonelyNathan",
    "productName": "LonelyNathan",
    "copyright": "Licensed under Apache-2.0.",
    "files": [
      "main.js",
      "preload.js",
      "lib/ollama-service.js",
      "lib/progress-cleaner.js",
      "shared.css",
      "shared.js",
      "loader.html",
      "about.html",
      "models.html",
      "LICENSE",
      "assets/icon.png",
      "assets/linux/icons/512x512.png",
      "assets/windows/icon.ico"
    ],
    "extraResources": [
      {
        "from": "compose.yaml",
        "to": "compose.yaml"
      },
      {
        "from": "ollama-credentials.json",
        "to": "ollama-credentials.json"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "icon": "assets/linux/icons"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "icon": "assets/macos/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/windows/icon.ico"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "lefthook": "^2.1.4",
    "rimraf": "^6.0.1"
  }
}
